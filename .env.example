# MovieFinder Environment Variables
# Copy to .env and fill in your values

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by CORS (no wildcard in prod).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Absolute path to the SQLite DB file. Defaults to <repo>/data/moviefinder.db.
# In production, point this OUTSIDE the deploy target so deploys never overwrite it.
# MOVIEFINDER_DB_PATH=/var/lib/moviefinder/moviefinder.db

# TMDB API Key (get one free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Backend URL used by the frontend. Leave unset to auto-detect (localhost or /api).
VITE_API_URL=http://localhost:8000
